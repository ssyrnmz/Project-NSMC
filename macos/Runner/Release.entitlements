<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox required for Mac App Store submission -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- ADDED: allows outbound HTTP/HTTPS calls to your PHP server -->
	<!-- Without this, ALL API calls fail silently on macOS in Release mode -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
